# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Pooled connection for Prisma in serverless/edge environments
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrate (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Impact.com API Credentials ──────────────────────────────────────────────
# Found in Impact dashboard → Settings → API
IMPACT_ACCOUNT_SID="your-account-sid"
IMPACT_AUTH_TOKEN="your-auth-token"

# ─── App Config ──────────────────────────────────────────────────────────────
# Secret for the Vercel Cron endpoint (set same value in Vercel env vars)
CRON_SECRET="generate-with: openssl rand -base64 32"
